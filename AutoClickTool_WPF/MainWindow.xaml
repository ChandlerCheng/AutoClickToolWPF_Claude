                                    <CheckBox Margin="2" Grid.Column="2" Grid.Row="0" Content="{DynamicResource labelAutoCheckBag}" Name="checkBagAuto"/>
                                    <RadioButton Margin="2" Grid.Column="1" Grid.Row="1" Foreground="{DynamicResource groupFontColor}"  GroupName="groupAuxiliary" VerticalAlignment="Center" Name="radioAutoBuyCrystallBox" Content="{DynamicResource labelAutoBuyCrystallBox}"/>
