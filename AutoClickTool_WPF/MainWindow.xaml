<Window x:Class="AutoClickTool_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Name="mainApp"
        ResizeMode="CanMinimize"
        Icon="Resources/favicon.ico"
        Title="{DynamicResource windowTitle}" Height="380" Width="480" Background="{DynamicResource groupWindowColor}">
    <Window.Resources>
        <ResourceDictionary>
            <!-- 設定值 --> 
            <system:String x:Key="labelVersionNumber">1.0.5.7A</system:String>
            <system:Double x:Key="ScrollViewerHeight">220</system:Double>
            <system:Double x:Key="lineWidth">400</system:Double>
            <system:Double x:Key="tabFontSize">16</system:Double>
            <!-- 深色模式 -->
            <SolidColorBrush x:Key="WindowColor_Night" Color="#3C3F41"/>
            <SolidColorBrush x:Key="FontColor_Night" Color="White"/>
            <SolidColorBrush x:Key="ButtonColor_Night" Color="#4E5052"/>
            <SolidColorBrush x:Key="BorderColor_Night" Color="#BBBBBB"/>
            <!-- 淺色模式 -->
            <SolidColorBrush x:Key="WindowColor_Day" Color="White"/>
            <SolidColorBrush x:Key="FontColor_Day" Color="Black"/>
            <SolidColorBrush x:Key="ButtonColor_Day" Color="#FFDDDDDD"/>
            <SolidColorBrush x:Key="BorderColor_Day" Color="#FF707070"/>
            <!-- 通用參數 -->
            <SolidColorBrush x:Key="groupWindowColor" Color="{Binding Color, Source={StaticResource WindowColor_Day}}"/>
            <SolidColorBrush x:Key="groupFontColor" Color="{Binding Color, Source={StaticResource FontColor_Day}}"/>
            <SolidColorBrush x:Key="groupButtonColor" Color="{Binding Color, Source={StaticResource ButtonColor_Day}}"/>
            <SolidColorBrush x:Key="groupBorderColor" Color="{Binding Color, Source={StaticResource BorderColor_Day}}"/>
        </ResourceDictionary>
    </Window.Resources>
    <DockPanel>
        <Grid Margin="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Vertical" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3">
                <StackPanel Orientation="Horizontal">
                    <Label Foreground="{DynamicResource groupFontColor}" FontSize="{DynamicResource tabFontSize}" Content="{DynamicResource labelVersion}"></Label>
                    <Label Foreground="{DynamicResource groupFontColor}" FontSize="16" Content="{DynamicResource labelVersionNumber}"></Label>
                    <Label Foreground="{DynamicResource groupFontColor}" FontSize="16" Name="labelBuildType"></Label>
                    <Label Foreground="{DynamicResource groupFontColor}" FontSize="16" Content="{DynamicResource labelHotkeyContent}"></Label>
                    <Label Foreground="{DynamicResource groupFontColor}" FontSize="16" Name="labelHotkeyDisplay"></Label>
                    <Label Foreground="{DynamicResource groupFontColor}" FontSize="16" Content="{DynamicResource labelLanguageChinese}"></Label>
                    <ComboBox FontSize="16" Name="comboLanguage" SelectionChanged="LanguageChange" SelectedIndex="0">
                        <ComboBoxItem Content="{DynamicResource comboLanguageChinese}"></ComboBoxItem>
                        <ComboBoxItem Content="{DynamicResource comboLanguageEnglish}"></ComboBoxItem>
                    </ComboBox>
                </StackPanel>
                <TabControl Name="tabControlUsingMethod" SelectionChanged ="tabControlUsingMethod_SelectionChanged" TabStripPlacement="Top">
                    <TabItem  FontSize="{DynamicResource tabFontSize}" Name="tabIndexPage" Header="{DynamicResource tabIndex}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Height="{StaticResource ScrollViewerHeight}">
                            <StackPanel Orientation="Vertical" Background="{DynamicResource groupWindowColor}"  Margin="2">
                                <Label Foreground="{DynamicResource groupFontColor}"  Content="{DynamicResource labelIndexTitle}" Visibility="Collapsed"></Label>
                                <TextBlock Foreground="{DynamicResource groupFontColor}" TextWrapping="Wrap" Text="{DynamicResource labelIndexItem1}" Visibility="Collapsed"></TextBlock>
                                <TextBlock Foreground="{DynamicResource groupFontColor}" TextWrapping="Wrap" Text="{DynamicResource labelIndexItem2}" Visibility="Collapsed"></TextBlock>
                                <TextBlock Foreground="{DynamicResource groupFontColor}" TextWrapping="Wrap" Text="{DynamicResource labelIndexItem3}" Visibility="Collapsed"></TextBlock>
                                <TextBlock Foreground="{DynamicResource groupFontColor}" TextWrapping="Wrap" Text="{DynamicResource labelIndexItem4}" Visibility="Collapsed"></TextBlock>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem FontSize="{DynamicResource tabFontSize}" Name="tabTestFunction" Header="{DynamicResource tabTestFunction}">
                        <!-- ScrollViewer 包圍內容 -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Height="{StaticResource ScrollViewerHeight}">
                            <StackPanel Background="{DynamicResource groupWindowColor}"  Margin="2" Orientation="Vertical">
                                <Expander Header="測試功能" IsExpanded="True">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition/>
                                            <ColumnDefinition/>
                                            <ColumnDefinition/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                        </Grid.RowDefinitions>
                                        <Label Grid.Row="0" Grid.Column="0" Content="X"/>
                                        <Label Grid.Row="0" Grid.Column="2" Content="Y"/>
                                        <Label Grid.Row="0" Grid.Column="1" Name="labelGetX"/>
                                        <Label Grid.Row="0" Grid.Column="3" Name="labelGetY"/>

                                        <Button Grid.Row="1" Grid.Column="0" FontSize="12" Foreground="{DynamicResource groupFontColor}" Background="{DynamicResource groupButtonColor}" BorderBrush="{DynamicResource groupBorderColor}" Width="Auto" HorizontalAlignment="Stretch" Name="btnCurrentStatusCheck" Height="40" Click="btnGetAllBmp_Click" Content="{DynamicResource btnCurrentStatusCheck}"></Button>
                                        <Button Grid.Row="1" Grid.Column="1" FontSize="12" Foreground="{DynamicResource groupFontColor}" Background="{DynamicResource groupButtonColor}" BorderBrush="{DynamicResource groupBorderColor}" Width="Auto" HorizontalAlignment="Stretch" Name="btnGetEnemyIndex" Height="40" Click="btnGetEnemyIndex_Click" Content="{DynamicResource btnGetEnemyIndex}"></Button>
                                        <Button Grid.Row="1" Grid.Column="2" FontSize="12" Foreground="{DynamicResource groupFontColor}" Background="{DynamicResource groupButtonColor}" BorderBrush="{DynamicResource groupBorderColor}" Width="Auto" HorizontalAlignment="Stretch" Name="btnGetEnemyIndexBmp" Height="40" Click="btnGetEnemyIndexBmp_Click" Content="{DynamicResource btnGetEnemyIndexBmp}"></Button>
                                        <Button Grid.Row="1" Grid.Column="3" FontSize="12" Foreground="{DynamicResource groupFontColor}" Background="{DynamicResource groupButtonColor}" BorderBrush="{DynamicResource groupBorderColor}"  Width="Auto" HorizontalAlignment="Stretch" Name="btnGetAllItem" Height="40" Click="btnGetAllItem_Click" Content="{DynamicResource btnGetAllItem}"></Button>
                                        <Button  Grid.Row="1" Grid.Column="4" FontSize="12" Foreground="{DynamicResource groupFontColor}" Background="{DynamicResource groupButtonColor}" BorderBrush="{DynamicResource groupBorderColor}"  Width="Auto" HorizontalAlignment="Stretch" Name="btnGetBattleMp" Height="40" Click="btnGetBattleMp_Click" Content ="取得戰鬥血魔"></Button>

                                        <Button Grid.Row="2" Grid.Column="0" FontSize="12" Foreground="{DynamicResource groupFontColor}" Background="{DynamicResource groupButtonColor}" BorderBrush="{DynamicResource groupBorderColor}"  HorizontalAlignment="Stretch" Name="btnGetTargetBmp" Click="btnGetTargetBmp_Click" Content="{DynamicResource btnGetTargetBmp}"></Button>
                                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Vertical">
                                            <Label Foreground="{DynamicResource groupFontColor}" FontSize="12"  Content="{DynamicResource labelGetTargetX}"></Label>
                                            <TextBox Height="20" Name="textGetTargetBmpX" PreviewTextInput ="textGetTargetBmp_PreviewTextInput"></TextBox>
                                        </StackPanel>
                                        <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Vertical">
                                            <Label Foreground="{DynamicResource groupFontColor}"  FontSize="12" Content="{DynamicResource labelGetTargetY}"></Label>
                                            <TextBox Height="20" Name="textGetTargetBmpY" PreviewTextInput ="textGetTargetBmp_PreviewTextInput"></TextBox>
                                        </StackPanel>
                                        <StackPanel Grid.Row="2" Grid.Column="3" Orientation="Vertical">
                                            <Label Foreground="{DynamicResource groupFontColor}"  FontSize="12" Content="{DynamicResource labelGetTargetWidth}"></Label>
                                            <TextBox Height="20" Name="textGetTargetBmpWidth" PreviewTextInput ="textGetTargetBmp_PreviewTextInput"></TextBox>
                                        </StackPanel>
                                        <StackPanel Grid.Row="2" Grid.Column="4" Orientation="Vertical">
                                            <Label Foreground="{DynamicResource groupFontColor}"  FontSize="12" Content="{DynamicResource labelGetTargetHeight}"></Label>
                                            <TextBox Height="20" Name="textGetTargetBmpHeight" PreviewTextInput ="textGetTargetBmp_PreviewTextInput"></TextBox>
                                        </StackPanel>
                                    </Grid>
                                </Expander>
                                <StackPanel Orientation="Horizontal">
                                    <StackPanel Orientation="Vertical">
                                        <StackPanel Orientation="Horizontal">

                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">

                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">

                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem FontSize="{DynamicResource tabFontSize}" Name="tabAutoBattle" Header="{DynamicResource tabAutoBattle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Height="{StaticResource ScrollViewerHeight}">
                            <StackPanel Orientation="Vertical" Background="{DynamicResource groupWindowColor}"  Margin="2">
                                <Expander Foreground="{DynamicResource groupFontColor}" Background="{DynamicResource groupWindowColor}"  BorderBrush="{DynamicResource groupBorderColor}" IsExpanded="True" Header="{DynamicResource commanHumanSetting}">
                                    <Grid Margin="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="AUTO"/>
                                            <ColumnDefinition  Width="AUTO"/>
                                            <ColumnDefinition Width="AUTO"/>
                                            <ColumnDefinition Width="AUTO"/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition/>
                                            <RowDefinition Height="10"/>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                        </Grid.RowDefinitions>

                                        <Label Foreground="{DynamicResource groupFontColor}" Grid.Row="0" Grid.Column="0" Content="{DynamicResource labelAttackKey}"/>
                                        <ComboBox  Margin="2" Grid.Row="0" Grid.Column="1" Name="tab2ComboPlayerActionKey" SelectedIndex="0"/>
                                        <Label Foreground="{DynamicResource groupFontColor}"  Grid.Row="0" Grid.Column="2" Name="tab2LabelAutoAttackKeyDebug"/>

                                        <CheckBox  Foreground="{DynamicResource groupFontColor}" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Name="tab2CheckAutoWalk" Content="{DynamicResource commanFunctionAutoWalk}"/>
                                        <CheckBox  Foreground="{DynamicResource groupFontColor}" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" Name="tab2CheckAutoWalk_OptionRandom" Content="{DynamicResource commanFunctionAutoWalk_OptionRandom}"/>
                                        <CheckBox  Foreground="{DynamicResource groupFontColor}" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Name="tab2CheckPvpMode" Content="{DynamicResource labelArenaMode}"/>
                                        <CheckBox  Foreground="{DynamicResource groupFontColor}" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" Name="tab2CheckLikeHuman" Content="增加隨機延遲"/>

                                    </Grid>
                                </Expander>
                                <Expander Foreground="{DynamicResource groupFontColor}" Background="{DynamicResource groupWindowColor}"  BorderBrush="{DynamicResource groupBorderColor}" IsExpanded="True" Header="{DynamicResource commanPetSetting}">
                                    <Grid Margin="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="AUTO"/>
                                            <ColumnDefinition  Width="AUTO"/>
                                            <ColumnDefinition Width="AUTO"/>
                                            <ColumnDefinition Width="AUTO"/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                        </Grid.RowDefinitions>

                                        <CheckBox  Foreground="{DynamicResource groupFontColor}" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Name="tab2CheckPetSupport"  Content="{DynamicResource labelPetSupport}"></CheckBox>
                                        <CheckBox  Foreground="{DynamicResource groupFontColor}" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Name="tab2CheckPetSupportJust1"  Content="施放一次"></CheckBox>

                                        <Label Foreground="{DynamicResource groupFontColor}" Grid.Row="1" Grid.Column="0" Content="{DynamicResource labelPetSupportKey}" ></Label>
                                        <ComboBox Margin="2" Grid.Row="1" Grid.Column="1" Name="tab2ComboPetActionKey" SelectedIndex="0"/>
                                        <Label Foreground="{DynamicResource groupFontColor}" Grid.Row="1" Grid.Column="2" Name="tab2LabelPetSupportKeyDebug"></Label>

                                        <Label Foreground="{DynamicResource groupFontColor}" Grid.Row="2" Grid.Column="0" Content="{DynamicResource labelPetSupportTarget}" ></Label>
                                        <ComboBox Margin="2" Grid.Row="2" Grid.Column="1" Name="tab2comboPetSupportTarget" SelectedIndex="0">
                                            <ComboBoxItem Content="{DynamicResource target1}" />
                                            <ComboBoxItem Content="{DynamicResource target2}" />
                                            <ComboBoxItem Content="{DynamicResource target3}" />
                                            <ComboBoxItem Content="{DynamicResource target4}" />
                                            <ComboBoxItem Content="{DynamicResource target5}" />
                                            <ComboBoxItem Content="{DynamicResource target6}" />
                                        </ComboBox>
                                    </Grid>
                                </Expander>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem FontSize="{DynamicResource tabFontSize}" Name="tabAutoDefend" Header="{DynamicResource tabAutoDefend}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Height="{StaticResource ScrollViewerHeight}">
                            <StackPanel Orientation="Vertical" Background="{DynamicResource groupWindowColor}" Margin="2">
                                <Expander Foreground="{DynamicResource groupFontColor}" Background="{DynamicResource groupWindowColor}"  BorderBrush="{DynamicResource groupBorderColor}" IsExpanded="True" Header="{DynamicResource commanHumanSetting}">
                                    <Grid Margin="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="AUTO"/>
                                            <ColumnDefinition  Width="AUTO"/>
                                            <ColumnDefinition Width="AUTO"/>
                                            <ColumnDefinition Width="AUTO"/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                        </Grid.RowDefinitions>

                                        <CheckBox  Foreground="{DynamicResource groupFontColor}" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Name="tab3CheckAutoWalk" Content="{DynamicResource commanFunctionAutoWalk}"></CheckBox>
                                        <CheckBox  Foreground="{DynamicResource groupFontColor}" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Name="tab3CheckAutoWalk_OptionRandom" Content="{DynamicResource commanFunctionAutoWalk_OptionRandom}"></CheckBox>

                                    </Grid>
                                </Expander>
                                <Expander Foreground="{DynamicResource groupFontColor}" Background="{DynamicResource groupWindowColor}"  BorderBrush="{DynamicResource groupBorderColor}" IsExpanded="True" Header="{DynamicResource commanPetSetting}">
                                    <Grid Margin="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="AUTO"/>
                                            <ColumnDefinition  Width="AUTO"/>
                                            <ColumnDefinition Width="AUTO"/>
                                            <ColumnDefinition Width="AUTO"/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                        </Grid.RowDefinitions>

                                        <Label Foreground="{DynamicResource groupFontColor}"  Grid.Row="0" Grid.Column="0" Content="{DynamicResource labelPetSupport}"></Label>
                                        <CheckBox  Foreground="{DynamicResource groupFontColor}"   Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" Name="tab3CheckPetSupport" ></CheckBox>

                                        <Label Foreground="{DynamicResource groupFontColor}" Grid.Row="1" Grid.Column="0" Content="{DynamicResource labelPetSupportKey}" ></Label>
                                        <ComboBox Margin="2" Grid.Row="1" Grid.Column="1" Name="tab3ComboPetActionKey" SelectedIndex="0"/>
                                        <Label Foreground="{DynamicResource groupFontColor}" Grid.Row="1" Grid.Column="2" Name="tab3LabelPetSupportKeyDebug"></Label>


                                        <Label Foreground="{DynamicResource groupFontColor}" Grid.Row="2" Grid.Column="0" Content="{DynamicResource labelPetSupportTarget}" />
                                        <ComboBox Margin="2" Grid.Row="2" Grid.Column="1" Name="tab3comboPetSupportTarget" SelectedIndex="0">
                                            <ComboBoxItem Content="{DynamicResource target1}" />
                                            <ComboBoxItem Content="{DynamicResource target2}" />
                                            <ComboBoxItem Content="{DynamicResource target3}" />
                                            <ComboBoxItem Content="{DynamicResource target4}" />
                                            <ComboBoxItem Content="{DynamicResource target5}" />
                                            <ComboBoxItem Content="{DynamicResource target6}" />
                                        </ComboBox>
                                    </Grid>
                                </Expander>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem FontSize="{DynamicResource tabFontSize}" Name="tabAutoEnterBattle" Header="{DynamicResource tabEnterBattleKey}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Height="{StaticResource ScrollViewerHeight}">
                            <StackPanel Orientation="Vertical" Background="{DynamicResource groupWindowColor}"  Margin="2">
                                <Expander Foreground="{DynamicResource groupFontColor}" Background="{DynamicResource groupWindowColor}"  BorderBrush="{DynamicResource groupBorderColor}" IsExpanded="True" Header="{DynamicResource commanHumanSetting}">
                                    <Grid Margin="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="AUTO"/>
                                            <ColumnDefinition  Width="AUTO"/>
                                            <ColumnDefinition Width="AUTO"/>
                                            <ColumnDefinition Width="AUTO"/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                        </Grid.RowDefinitions>

                                        <Label Foreground="{DynamicResource groupFontColor}" Grid.Row="0" Grid.Column="0" Content="{DynamicResource labelSummonKey}"></Label>
                                        <ComboBox Margin="2" Grid.Row="0" Grid.Column="1" Name="tab4ComboSummonerActionKey" SelectedIndex="0"></ComboBox>
                                        <Label Foreground="{DynamicResource groupFontColor}" Grid.Row="0" Grid.Column="2" Name="tab4LabelSummonKeyDebug"></Label>

                                        <CheckBox  Foreground="{DynamicResource groupFontColor}"  Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Name="tab4CheckSummonAttack" Content="{DynamicResource labelSummonAttackKey}"></CheckBox>
                                        <Label Foreground="{DynamicResource groupFontColor}" Grid.Row="2" Grid.Column="0" Content="{DynamicResource labelAttackKey}"></Label>
                                        <ComboBox Margin="2" Grid.Row="2" Grid.Column="1" Name="tab4ComboSummonerAttackKey" SelectedIndex="1"></ComboBox>
                                        <Label Foreground="{DynamicResource groupFontColor}" Grid.Row="2" Grid.Column="2" Name="tab4LabelSummonAttackKeyDebug"></Label>
                                    </Grid>
                                </Expander>
                                <Expander Foreground="{DynamicResource groupFontColor}" Background="{DynamicResource groupWindowColor}"  BorderBrush="{DynamicResource groupBorderColor}" IsExpanded="True" Header="{DynamicResource commanPetSetting}">
                                    <Grid Margin="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="AUTO"/>
                                            <ColumnDefinition  Width="AUTO"/>
                                            <ColumnDefinition Width="AUTO"/>
                                            <ColumnDefinition Width="AUTO"/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                        </Grid.RowDefinitions>

                                        <CheckBox  Margin="2" Foreground="{DynamicResource groupFontColor}" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"  Name="tab4CheckPetSupport" Content="{DynamicResource labelPetSupport}" ></CheckBox>
                                        <Label Foreground="{DynamicResource groupFontColor}" Grid.Row="1" Grid.Column="0" Content="{DynamicResource labelPetSupportKey}" ></Label>
                                        <ComboBox Margin="2" Grid.Row="1" Grid.Column="1" Name="tab4ComboPetActionKey" SelectedIndex="0"></ComboBox>
                                        <Label Foreground="{DynamicResource groupFontColor}" Grid.Row="1" Grid.Column="2" Name="tab4LabelPetSupportKeyDebug"></Label>

                                        <Label Foreground="{DynamicResource groupFontColor}" Grid.Row="2" Grid.Column="0" Content="{DynamicResource labelPetSupportTarget}" ></Label>
                                        <ComboBox Margin="2" Grid.Row="2" Grid.Column="1" Name="tab4comboPetSupportTarget" SelectedIndex="0">
                                            <ComboBoxItem Content="{DynamicResource target1}" />
                                            <ComboBoxItem Content="{DynamicResource target2}" />
                                            <ComboBoxItem Content="{DynamicResource target3}" />
                                            <ComboBoxItem Content="{DynamicResource target4}" />
                                            <ComboBoxItem Content="{DynamicResource target5}" />
                                            <ComboBoxItem Content="{DynamicResource target6}" />
                                        </ComboBox>
                                    </Grid>
                                </Expander>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem FontSize="{DynamicResource tabFontSize}" Name="tabAutoBuff" Header="{DynamicResource tabBuffTarget}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Height="{StaticResource ScrollViewerHeight}">
                            <StackPanel Orientation="Vertical" Background="{DynamicResource groupWindowColor}"  Margin="2">
                                <Expander Foreground="{DynamicResource groupFontColor}" Background="{DynamicResource groupWindowColor}" BorderBrush="{DynamicResource groupBorderColor}" IsExpanded="True" Header="{DynamicResource commanHumanSetting}">
                                    <Grid Margin="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="AUTO"/>
                                            <ColumnDefinition  Width="AUTO"/>
                                            <ColumnDefinition Width="AUTO"/>
                                            <ColumnDefinition Width="AUTO"/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                            <RowDefinition Height="10"/>
                                            <RowDefinition/>
                                        </Grid.RowDefinitions>

                                        <Label Foreground="{DynamicResource groupFontColor}" Grid.Row="0" Grid.Column="0" Content="{DynamicResource labelBuffKey}"></Label>
                                        <ComboBox Margin="2" Grid.Row="0" Grid.Column="1" Name="tab5ComboAutoBuffKey" SelectedIndex="0"></ComboBox>
                                        <Label Foreground="{DynamicResource groupFontColor}" Grid.Row="0" Grid.Column="2" Name="tab5LabelAutoBuffKeyDebug"></Label>

                                        <Label Foreground="{DynamicResource groupFontColor}"  Grid.Row="1" Grid.Column="0" Content="{DynamicResource labelBuffTarget}"></Label>
                                        <ComboBox  Margin="2" Grid.Row="1" Grid.Column="1" Name="tab5comboAutoBuffTarget" SelectedIndex="0">
                                            <ComboBoxItem Content="{DynamicResource target1}" />
                                            <ComboBoxItem Content="{DynamicResource target2}" />
                                            <ComboBoxItem Content="{DynamicResource target3}" />
                                            <ComboBoxItem Content="{DynamicResource target4}" />
                                            <ComboBoxItem Content="{DynamicResource target5}" />
                                        </ComboBox>

                                        <CheckBox  Margin="2" Foreground="{DynamicResource groupFontColor}"    Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Name="tab5CheckAutoWalk" Content="{DynamicResource commanFunctionAutoWalk}"></CheckBox>
                                        <CheckBox  Margin="2" Foreground="{DynamicResource groupFontColor}"   Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" Name="tab5CheckAutoWalk_OptionRandom" Content="{DynamicResource commanFunctionAutoWalk_OptionRandom}"></CheckBox>
                                    </Grid>
                                </Expander>
                                <Expander Foreground="{DynamicResource groupFontColor}" Background="{DynamicResource groupWindowColor}"  BorderBrush="{DynamicResource groupBorderColor}" IsExpanded="True" Header="{DynamicResource commanPetSetting}">
                                    <Grid Margin="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="AUTO"/>
                                            <ColumnDefinition  Width="AUTO"/>
                                            <ColumnDefinition Width="AUTO"/>
                                            <ColumnDefinition Width="AUTO"/>
                                            <ColumnDefinition/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                            <RowDefinition/>
                                        </Grid.RowDefinitions>

                                        <CheckBox  Foreground="{DynamicResource groupFontColor}"  Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Name="tab5CheckPetSupport" Content="{DynamicResource labelPetSupport}"></CheckBox>

                                        <Label Foreground="{DynamicResource groupFontColor}" Grid.Row="1" Grid.Column="0" Content="{DynamicResource labelPetSupportKey}" ></Label>
                                        <ComboBox Margin="2" Grid.Row="1" Grid.Column="1"  Name="tab5ComboPetActionKey" SelectedIndex="0"></ComboBox>
                                        <Label Foreground="{DynamicResource groupFontColor}" Grid.Row="1" Grid.Column="2"  Name="tab5LabelPetSupportKeyDebug"></Label>

                                        <Label Foreground="{DynamicResource groupFontColor}"  Grid.Row="2" Grid.Column="0" Content="{DynamicResource labelPetSupportTarget}" ></Label>
                                        <ComboBox  Margin="2" Grid.Row="2" Grid.Column="1" Name="tab5comboPetSupportTarget" SelectedIndex="0">
                                            <ComboBoxItem Content="{DynamicResource target1}" />
                                            <ComboBoxItem Content="{DynamicResource target2}" />
