                    </TabItem>
                    <TabItem FontSize="{DynamicResource tabFontSize}" Name="tabAuxiliaryFunctions" Header="{DynamicResource tabAuxiliaryFunctions}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Height="{StaticResource ScrollViewerHeight}" >
                            <StackPanel Background="{DynamicResource groupWindowColor}" Orientation="Vertical"   Margin="2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
